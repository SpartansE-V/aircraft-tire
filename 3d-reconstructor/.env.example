# MASt3R reconstruction service
API_PORT=8000

# Model + device
MAST3R_MODEL_NAME=naver/MASt3R_ViTLarge_BaseDecoder_512_catmlpdpt_metric
MAST3R_DEVICE=auto            # auto | cuda | cpu
MAST3R_IMAGE_SIZE=512         # 512 (recommended) or 224
MAST3R_MIN_CONF_THR=1.5
MAST3R_OPTIM_LEVEL=refine+depth   # coarse | refine | refine+depth

# Workspace (mounted volume)
MAST3R_WORKSPACE_ROOT=/app/workspace
MAST3R_IMAGES_ROOT=/app/workspace/images
MAST3R_OUTPUTS_ROOT=/app/workspace/runs
