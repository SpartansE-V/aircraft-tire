# Prefer building from the repo root so assets/mock-tyres are included:
#   docker build -f app/Dockerfile -t wear-severity-api .
# The root .dockerignore applies in that case.
#
# This file only applies when the build context is app/ itself
# (`docker build app`), which omits mock-tyre assets and breaks enrich-scans.

# VCS / caches / envs
.git
.gitignore
.venv
venv
env
__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
.env
.env.*
.DS_Store
.claude

# Heavy research artifacts — not needed to serve the API.
tire_rul/data/_ground_truth.parquet
tire_rul/data/scans/
tire_rul/artifacts/mixedlm.pkl
tire_rul/artifacts/lightgbm.txt
tire_rul/artifacts/weibull_aft.pkl
tire_rul/artifacts/shap_values.parquet
tire_rul/artifacts/eval_report.json
