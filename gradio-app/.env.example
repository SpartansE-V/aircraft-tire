# Roboflow hosted inference
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_API_KEY=your-roboflow-api-key

# Detection models (mirror the crack-detector service defaults)
CRACK_MODEL_ID=tyre-quality-qccvy/1
TREAD_MODEL_ID=tyre_tread_depth_set/1

# MASt3R reconstructor service (HTTP)
RECONSTRUCTOR_API_URL=http://localhost:8000
RECONSTRUCTOR_POLL_INTERVAL=3
RECONSTRUCTOR_JOB_TIMEOUT=1800

# MASt3R reconstruction defaults (surfaced in the UI)
MAST3R_IMAGE_SIZE=512
MAST3R_MIN_CONF_THR=1.5
MAST3R_OPTIM_LEVEL=refine+depth

# Workspace + Gradio server
GRADIO_WORKSPACE_ROOT=./workspace
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
APP_PORT=7860
